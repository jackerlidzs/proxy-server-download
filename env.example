# Server URL (used for generating download/stream links)
SERVER_URL=http://your-server-ip:8080

# Authentication
API_KEY=your-secret-key
JWT_SECRET=change-this-to-random-string

# Port
PORT=8080

# Download settings
MAX_CONNECTIONS=16
MAX_CONCURRENT_DOWNLOADS=3
CLEANUP_HOURS=48

# File management
TRASH_EXPIRE_DAYS=7
MAX_VERSIONS=5
