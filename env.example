# === Download Proxy Server Configuration ===

# Port to expose (default: 8080)
PORT=8080

# API Key for authentication (change this!)
API_KEY=changeme

# Your server's public URL (used for generating download links)
# Example: http://your-server-ip:8080 or https://dl.yourdomain.com
SERVER_URL=http://localhost:8080

# Max connections per download (aria2c, default: 16)
MAX_CONNECTIONS=16

# Auto-delete files older than X hours (default: 48)
CLEANUP_HOURS=48

# Max concurrent downloads (default: 3)
MAX_CONCURRENT_DOWNLOADS=3
